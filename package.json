{
  "name": "confetti",
  "version": "0.0.0",
  "type": "module",
  "description": "Layered, schema-first TypeScript config — inspired by spf13/viper",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./parsers/*": {
      "types": "./dist/parsers/*.d.ts",
      "import": "./dist/parsers/*.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "keywords": [
    "config",
    "configuration",
    "viper",
    "typescript",
    "zod",
    "schema",
    "layered"
  ],
  "devDependencies": {
    "@types/node": "^22.10.0",
    "expect-type": "^1.1.0",
    "oxlint": "^0.15.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "json5": "^2.2.0",
    "smol-toml": "^1.3.0",
    "yaml": "^2.6.0",
    "zod": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "json5": {
      "optional": true
    },
    "smol-toml": {
      "optional": true
    },
    "yaml": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  }
}
